
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rastreador de Cliques</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            width: 100%;
            height: 100vh;
            background-color: white;
            cursor: crosshair;
            font-family: Arial, sans-serif;
            overflow: hidden;
        }

        .click-info {
            position: fixed;
            background-color: rgba(0, 0, 0, 0.8);
            color: white;
            padding: 10px 15px;
            border-radius: 5px;
            font-size: 14px;
            pointer-events: none;
            z-index: 1000;
        }

        .click-dot {
            position: absolute;
            width: 10px;
            height: 10px;
            background-color: red;
            border-radius: 50%;
            pointer-events: none;
            transform: translate(-50%, -50%);
        }

        #counter {
            position: fixed;
            top: 20px;
            left: 20px;
            background-color: rgba(0, 0, 0, 0.7);
            color: white;
            padding: 15px 20px;
            border-radius: 5px;
            font-size: 16px;
            z-index: 999;
        }

        #clearBtn {
            position: fixed;
            bottom: 20px;
            right: 20px;
            padding: 10px 20px;
            background-color: rgba(0, 0, 0, 0.7);
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 14px;
            z-index: 999;
        }

        #clearBtn:hover {
            background-color: rgba(0, 0, 0, 0.9);
        }
    </style>
</head>
<body>
    <br>
    <br>
    <div id="counter">Cliques: 0</div>
    <button id="clearBtn">Limpar</button>

    <script>
        let clickCount = 0;

        document.addEventListener('click', function(event) {
            clickCount++;

            // Criar ponto no local do clique
            const dot = document.createElement('div');
            dot.className = 'click-dot';
            dot.style.left = event.clientX + 'px';
            dot.style.top = event.clientY + 'px';
            document.body.appendChild(dot);

            // Criar informação de coordenadas
            const info = document.createElement('div');
            info.className = 'click-info';
            info.style.left = (event.clientX + 15) + 'px';
            info.style.top = (event.clientY - 30) + 'px';
            info.textContent = `X: ${event.clientX} | Y: ${event.clientY}`;
            document.body.appendChild(info);

            // Atualizar contador
            document.getElementById('counter').textContent = `Cliques: ${clickCount}`;

            // Remover a informação após 3 segundos
            setTimeout(() => {
                info.remove();
            }, 3000);

            // Remover o ponto após 5 segundos
            setTimeout(() => {
                dot.remove();
            }, 5000);
        });

        // Botão para limpar
        document.getElementById('clearBtn').addEventListener('click', function(event) {
            event.stopPropagation();
            document.querySelectorAll('.click-dot, .click-info').forEach(el => el.remove());
            clickCount = 0;
            document.getElementById('counter').textContent = 'Cliques: 0';
        });
    </script>
</body>
</html>
